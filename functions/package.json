{
  "name": "geo-attendance-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Geo-Attendance System",
  "scripts": {
    "build": "tsc",
    "dev": "firebase emulators:start --import=./emulator-data",
    "deploy": "firebase deploy --only functions",
    "serve": "firebase serve --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-functions": "^4.4.1",
    "firebase-admin": "^12.0.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.14.2",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "firebase-tools": "^13.8.0"
  },
  "engines": {
    "node": "18"
  }
}
