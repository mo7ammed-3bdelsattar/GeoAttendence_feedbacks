# Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Server ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Firebase Admin SDK ─────────────────────────────
# Set your project ID so Firestore constructor knows what to hit
FIREBASE_PROJECT_ID=geo-attendance-6e1a4
FIREBASE_DATABASE_URL=https://geo-attendance-6e1a4-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=geo-attendance-6e1a4.firebasestorage.app

# Option A: path to your serviceAccountKey.json file
FIREBASE_SERVICE_ACCOUNT_PATH=./src/assets/service-account.json

# Option B: individual fields (Alternative if you don't have the file)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── CORS ───────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8081,http://localhost:8082,http://192.168.1.194:8081,http://192.168.1.194:5000,http://172.18.102.29:5000,http://172.18.102.29:8081

# ── Frontend API ────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
GOOGLE_GEMINI_API_KEY=AIzaSyBkbJJIVet7Z0rGjHQQrr6B_WhtE830j0k
